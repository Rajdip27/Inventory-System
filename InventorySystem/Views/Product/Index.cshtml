@using InventorySystem.Cmmon
@using InventorySystem.HealperUnit
@inject ISignInHelper SignInHelper
@model PaginationModel<Product>

@{
    string currentSearch = Context.Request.Query["search"].ToString() ?? "";
    int sl = (Model?.PageNumber - 1) * Model.PageSize + 1 ?? 1;
}

<div class="page-content">

    <!-- TABLE CARD -->
    <div class="table-card">

        <!-- HEADER -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">Product List</h5>
                <small class="table-card-subtitle">
                    Manage all products • @Model?.TotalItems items
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <!-- SEARCH -->
                <form method="get" class="d-flex gap-2">
                    <div class="search-field" style="width: 280px;">
                        <i class="ri-search-line"></i>
                        <input type="text"
                               name="search"
                               class="toolbar-input"
                               placeholder="Search product name, SKU, barcode..."
                               value="@currentSearch" />
                        <input type="hidden" name="page" value="1" />
                    </div>

                    <button class="btn btn-primary-sm" type="submit">
                        <i class="ri-search-line"></i>
                    </button>
                </form>

                <!-- CREATE -->
                <a asp-controller="Product"
                   asp-action="CreateAndEdit"
                   class="btn btn-primary-sm d-flex align-items-center gap-2">
                    <i class="ri-add-line"></i> New Product
                </a>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">SL</th>
                        <th>Product Name</th>
                        <th>SKU</th>
                        <th>Barcode</th>
                        <th>Purchase Price</th>
                        <th>Selling Price</th>
                        <th>Warranty</th>
                        <th>Status</th>
                        <th style="width: 110px;" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-center fw-medium">@sl</td>

                                <td class="fw-semibold">@item.ProductName</td>

                                <td>@item.Sku</td>

                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <div style="
                                            font-family: 'Libre Barcode 39', cursive;
                                            font-size: 32px;
                                            letter-spacing: 2px;">

                                            *@item.Barcode*
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Barcode</span>
                                    }
                                </td>

                                <td>@item.PurchasePrice</td>

                                <td>@item.SellingPrice</td>

                                <td>@item.WarrantyMonths months</td>

                                <td>
                                    @if (item.Status)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="action-btns">

                                        <!-- EDIT -->
                                        <a asp-controller="Product"
                                           asp-action="CreateAndEdit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--edit"
                                           title="Edit">
                                            <i class="ri-edit-line"></i>
                                        </a>

                                        <!-- DELETE -->
                                        <a href="javascript:void(0);"
                                           class="btn btn-danger btn-sm"
                                           onclick="confirmDelete('/Product/Delete/@item.Id')">
                                            <i class="ri-delete-bin-6-line"></i>
                                        </a>

                                    </div>
                                </td>
                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="empty-state">
                                <i class="ri-inbox-line" style="font-size: 42px;"></i>
                                <p>No products found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination-bar">
            <partial name="_Pagination" model="Model" />
        </div>

    </div>
</div>