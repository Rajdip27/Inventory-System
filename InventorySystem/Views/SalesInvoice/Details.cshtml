<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IT Fix Service Center - Invoice</title>
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: Arial, sans-serif;
                background: #f0f0f0;
                display: flex;
                justify-content: center;
                padding: 30px 10px;
            }

            .invoice-wrapper {
                max-width: 720px;
                width: 100%;
                background: #fff;
                color: #000;
                border: 1px solid #ccc;
                padding: 28px;
            }

            /* Header */
            .header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 12px;
            }

            .company-name {
                font-size: 22px;
                font-weight: 700;
                letter-spacing: 1px;
                margin-bottom: 4px;
            }

            .company-info {
                font-size: 12px;
                color: #333;
                line-height: 1.7;
            }

                .company-info a {
                    color: #333;
                    text-decoration: underline;
                }

            .logo-block {
                text-align: center;
            }

            .logo-circle {
                width: 82px;
                height: 82px;
                border: 2px solid #000;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 6px;
            }

            .logo-circle-inner {
                text-align: center;
                line-height: 1.3;
            }

                .logo-circle-inner .main {
                    font-size: 10px;
                    font-weight: 700;
                }

                .logo-circle-inner .sub {
                    font-size: 7.5px;
                    color: #555;
                }

            .invoice-title {
                font-size: 18px;
                font-weight: 700;
                letter-spacing: 2px;
                text-align: center;
                margin-top: 4px;
            }

            hr.thick {
                border: none;
                border-top: 2px solid #000;
                margin: 10px 0;
            }

            hr.thin {
                border: none;
                border-top: 1px solid #000;
                margin: 14px 0;
            }

            /* Bill To + Invoice Meta */
            .meta-row {
                display: flex;
                justify-content: space-between;
                margin-bottom: 10px;
            }

            .bill-to-label {
                font-size: 11px;
                font-weight: 700;
                color: #555;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-bottom: 5px;
            }

            .bill-to-name {
                font-size: 13px;
                font-weight: 700;
                margin-bottom: 2px;
            }

            .bill-to-info {
                font-size: 12px;
                color: #333;
                line-height: 1.7;
            }

            .meta-table {
                font-size: 12px;
                border-collapse: collapse;
                margin-left: auto;
            }

                .meta-table td {
                    padding: 2px 0 2px 8px;
                }

                .meta-table .label {
                    color: #555;
                    font-weight: 600;
                    text-align: right;
                    padding-right: 10px;
                }

            .paid-badge {
                display: inline-block;
                border: 2px solid #000;
                padding: 3px 20px;
                font-weight: 700;
                font-size: 13px;
                letter-spacing: 2px;
                margin-top: 10px;
                float: right;
            }

            /* Items Table */
            .items-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 12px;
            }

                .items-table thead tr {
                    background: #000;
                    color: #fff;
                }

                .items-table thead th {
                    padding: 8px 10px;
                    text-align: left;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }

                    .items-table thead th.center {
                        text-align: center;
                    }

                    .items-table thead th.right {
                        text-align: right;
                    }

                .items-table tbody tr {
                    border-bottom: 0.5px solid #ddd;
                }

                    .items-table tbody tr.alt {
                        background: #f9f9f9;
                    }

                .items-table tbody td {
                    padding: 12px 10px;
                    color: #000;
                }

                    .items-table tbody td.desc {
                        font-weight: 600;
                    }

                    .items-table tbody td.center {
                        text-align: center;
                    }

                    .items-table tbody td.right {
                        text-align: right;
                        font-weight: 600;
                    }

            /* Totals */
            .totals-wrap {
                display: flex;
                justify-content: flex-end;
                margin-top: 10px;
            }

            .totals-table {
                font-size: 12px;
                min-width: 290px;
                border-collapse: collapse;
            }

                .totals-table td {
                    padding: 4px 0;
                }

                .totals-table .t-label {
                    color: #555;
                    text-align: right;
                    padding-right: 14px;
                    text-transform: uppercase;
                    letter-spacing: 0.4px;
                }

                .totals-table .t-value {
                    text-align: right;
                    min-width: 90px;
                }

                .totals-table tr.grand td {
                    border-top: 2px solid #000;
                    border-bottom: 2px solid #000;
                    padding: 8px 0;
                }

                .totals-table tr.grand .t-label {
                    font-weight: 700;
                    font-size: 14px;
                }

                .totals-table tr.grand .t-value {
                    font-weight: 700;
                    font-size: 16px;
                }

            /* Terms */
            .terms-title {
                font-size: 13px;
                font-weight: 700;
                text-decoration: underline;
                margin-bottom: 7px;
            }

            .terms-list {
                padding-left: 18px;
                font-size: 11px;
                color: #222;
                line-height: 1.85;
            }

                .terms-list li.highlight {
                    font-weight: 600;
                }

                .terms-list li.small {
                    font-size: 10.5px;
                    color: #444;
                }

            /* Signatures */
            .sig-row {
                display: flex;
                justify-content: space-between;
                align-items: flex-end;
                margin-top: 14px;
            }

            .sig-block {
                text-align: center;
                flex: 1;
            }

            .sig-line {
                border-top: 1.5px solid #000;
                margin-top: 48px;
                padding-top: 6px;
                font-size: 12px;
                font-weight: 600;
            }

            .qr-box {
                width: 72px;
                height: 72px;
                border: 1.5px solid #000;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto;
            }

            .qr-inner {
                display: grid;
                grid-template-columns: repeat(7, 1fr);
                grid-template-rows: repeat(7, 1fr);
                width: 58px;
                height: 58px;
                gap: 1.5px;
            }

                .qr-inner span {
                    background: #000;
                    border-radius: 0.5px;
                }

                    .qr-inner span.w {
                        background: #fff;
                    }

            @@media print {
                body {
                    background: #fff;
                    padding: 0;
                }

                .invoice-wrapper {
                    border: none;
                    box-shadow: none;
                }
            }
    </style>
</head>
