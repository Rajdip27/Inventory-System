@model SalesInvoice

<style>
    /* =======================
       INFO BOX
    ======================= */
    .info-box {
        background: var(--card-bg, #fff);
        border: 1px solid var(--border-color, #e9ecef);
        border-radius: 12px;
        padding: 20px;
    }

    /* =======================
       ITEM TABLE
    ======================= */
    .invoice-table th,
    .invoice-table td {
        background: transparent !important;
        color: var(--text-color, #000);
    }

    /* =======================
       SUMMARY TABLE (FIX)
    ======================= */
    .invoice-summary-table {
        margin-bottom: 0;
        background: transparent;
    }

        .invoice-summary-table th,
        .invoice-summary-table td {
            padding: 10px 14px;
            border-bottom: 1px solid var(--border-color, #e9ecef);
            background: transparent !important;
            color: var(--text-color, #000);
        }

        .invoice-summary-table th {
            font-weight: 600;
        }

        .invoice-summary-table .total-row th,
        .invoice-summary-table .total-row td {
            font-size: 16px;
            font-weight: 700;
        }

    /* =======================
       DARK MODE FIX (IMPORTANT)
    ======================= */

    /* CASE 1: body.dark-mode */
    body.dark-mode .info-box,
    body.dark-mode .invoice-summary-table th,
    body.dark-mode .invoice-summary-table td,
    body.dark-mode .invoice-table th,
    body.dark-mode .invoice-table td {
        background: transparent !important;
        color: #e5e7eb !important;
        border-color: #374151 !important;
    }

    /* CASE 2: data-theme="dark" */
    [data-theme="dark"] .info-box,
    [data-theme="dark"] .invoice-summary-table th,
    [data-theme="dark"] .invoice-summary-table td,
    [data-theme="dark"] .invoice-table th,
    [data-theme="dark"] .invoice-table td {
        background: transparent !important;
        color: #e5e7eb !important;
        border-color: #374151 !important;
    }

    /* CASE 3: bootstrap 5 dark mode */
    [data-bs-theme="dark"] .info-box,
    [data-bs-theme="dark"] .invoice-summary-table th,
    [data-bs-theme="dark"] .invoice-summary-table td,
    [data-bs-theme="dark"] .invoice-table th,
    [data-bs-theme="dark"] .invoice-table td {
        background: transparent !important;
        color: #e5e7eb !important;
        border-color: #374151 !important;
    }
</style>

<div class="page-content">

    <div class="table-card">

        <!-- HEADER -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">
                    Invoice Details
                </h5>

                <small class="table-card-subtitle">
                    Invoice No : @Model.InvoiceNo
                </small>
            </div>

            <div>
                <a asp-action="Index" class="btn btn-secondary-sm">
                    <i class="ri-arrow-left-line"></i> Back
                </a>

                <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-primary-sm">
                    <i class="ri-printer-line"></i> Print
                </a>
            </div>
        </div>

        <!-- CUSTOMER + INVOICE INFO -->
        <div class="row p-4">

            <div class="col-md-6">
                <div class="info-box">

                    <h6 class="fw-bold mb-3">Customer Information</h6>

                    <p><strong>Name :</strong> @Model.Customer?.Name</p>
                    <p><strong>Phone :</strong> @Model.Customer?.Phone</p>
                    <p><strong>Address :</strong> @Model.Customer?.Address</p>

                </div>
            </div>

            <div class="col-md-6">
                <div class="info-box">

                    <h6 class="fw-bold mb-3">Invoice Information</h6>

                    <p><strong>Invoice No :</strong> @Model.InvoiceNo</p>

                    <p>
                        <strong>Date :</strong>
                        @Model.InvoiceDate.ToString("dd-MMM-yyyy")
                    </p>

                    <p>
                        <strong>Status :</strong>

                        @if (Model.DueAmount <= 0)
                        {
                            <span class="badge bg-success">Paid</span>
                        }
                        else if (Model.PaidAmount > 0)
                        {
                            <span class="badge bg-warning">Partial</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Unpaid</span>
                        }
                    </p>

                </div>
            </div>

        </div>

        <!-- ITEM LIST -->
        <div class="table-responsive px-4 pb-4">

            <table class="data-table invoice-table">

                <thead>
                    <tr>
                        <th>SL</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int sl = 1;
                    }

                    @foreach (var item in Model.SalesItem)
                    {
                        <tr>
                            <td>@sl</td>
                            <td>@item.Product?.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("N2")</td>
                            <td>@item.Total.ToString("N2")</td>
                        </tr>

                        sl++;
                    }
                </tbody>

            </table>

        </div>

        <!-- SUMMARY -->
        <div class="row px-4 pb-4">

            <div class="col-md-4 offset-md-8">

                <table class="table invoice-summary-table">

                    <tr>
                        <th>Discount</th>
                        <td class="text-end">@Model.Discount.ToString("N2")</td>
                    </tr>

                    <tr>
                        <th>Tax</th>
                        <td class="text-end">@Model.Tax.ToString("N2")</td>
                    </tr>

                    <tr>
                        <th>VAT</th>
                        <td class="text-end">@Model.Vat.ToString("N2")</td>
                    </tr>

                    <tr class="total-row">
                        <th>Grand Total</th>
                        <td class="text-end fw-bold">@Model.GrandTotal.ToString("N2")</td>
                    </tr>

                    <tr>
                        <th>Paid Amount</th>
                        <td class="text-end text-success fw-bold">
                            @Model.PaidAmount.ToString("N2")
                        </td>
                    </tr>

                    <tr>
                        <th>Due Amount</th>
                        <td class="text-end text-danger fw-bold">
                            @Model.DueAmount.ToString("N2")
                        </td>
                    </tr>

                </table>

            </div>

        </div>

    </div>

</div>