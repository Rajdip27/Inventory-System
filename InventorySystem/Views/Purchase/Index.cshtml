@using InventorySystem.Cmmon
@using InventorySystem.HealperUnit
@inject ISignInHelper SignInHelper
@model PaginationModel<InventorySystem.Models.Purchase>

@{
    string currentSearch = Context.Request.Query["search"].ToString() ?? "";
    int sl = ((Model?.PageNumber - 1) * Model?.PageSize ?? 0) + 1;
}

<div class="page-content">

    <!-- TABLE CARD -->
    <div class="table-card">

        <!-- Header -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">Purchase List</h5>
                <small class="table-card-subtitle">
                    Manage all purchases • @Model?.TotalItems items
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <!-- Search -->
                <form method="get" class="d-flex gap-2">
                    <div class="search-field" style="width: 280px;">
                        <i class="ri-search-line"></i>
                        <input type="text"
                               name="search"
                               class="toolbar-input"
                               placeholder="Search invoice no..."
                               value="@currentSearch" />
                        <input type="hidden" name="page" value="1" />
                    </div>
                    <button class="btn btn-primary-sm" type="submit">
                        <i class="ri-search-line"></i>
                    </button>
                </form>

                <!-- Create Button -->
                <a asp-controller="Purchase"
                   asp-action="CreateAndEdit"
                   class="btn btn-primary-sm d-flex align-items-center gap-2">
                    <i class="ri-add-line"></i> New Purchase
                </a>

            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">SL</th>
                        <th>Invoice No</th>
                        <th>Supplier ID</th>
                        <th>Purchase Date</th>
                        <th>Items</th>
                        <th>Discount</th>
                        <th>Transport</th>
                        <th style="width: 110px;" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-center fw-medium">@sl</td>

                                <td class="fw-semibold">
                                    @item.InvoiceNo
                                </td>

                                <td>
                                    @item.Supplier.Name
                                </td>

                                <td>
                                    @item.PurchaseDate.ToString("dd-MM-yyyy")
                                </td>

                                <td>
                                    @(item.StockEntries?.Count ?? 0)
                                </td>

                                <td>
                                    @item.Discount
                                </td>

                                <td>
                                    @item.TransportCost
                                </td>

                                <td class="text-center">
                                    <div class="action-btns">

                                        <!-- Edit -->
                                        <a asp-controller="Purchase"
                                           asp-action="CreateAndEdit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--edit"
                                           title="Edit">
                                            <i class="ri-edit-line"></i>
                                        </a>

                                        <!-- Details -->
                                        <a asp-controller="Purchase"
                                           asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--view"
                                           title="Details">
                                            <i class="ri-eye-line"></i>
                                        </a>

                                    </div>
                                </td>
                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="ri-inbox-line" style="font-size: 42px;"></i>
                                <p>No purchases found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-bar">
            <partial name="_Pagination" model="Model" />
        </div>

    </div>

</div>