@model Purchase
@using System.Text.Json

@{
    bool isEdit = Model?.Id > 0;
    var items = Model?.PurchaseItem ?? new List<PurchaseItem>();
}

<div class="page-content">
    <div class="table-card">

        <!-- HEADER (same as Customer design) -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">
                    @(isEdit ? "Edit Purchase" : "New Purchase")
                </h5>
                <small class="table-card-subtitle">
                    Multi Product Purchase System
                </small>
            </div>

            <div>
                <a asp-action="Index" class="btn btn-outline-sm">
                    Back to List
                </a>
            </div>
        </div>

        <!-- FORM BODY -->
        <div class="p-5">

            <form asp-action="CreateAndEdit" method="post" class="row g-4">

                @if (isEdit)
                {
                    <input type="hidden" asp-for="Id" />
                }

                <!-- Invoice -->
                <div class="col-md-3">
                    <label class="form-label fw-medium">Invoice No</label>
                    <input asp-for="InvoiceNo" class="toolbar-input" />
                </div>

                <!-- Supplier -->
                <div class="col-md-3">
                    <label class="form-label fw-medium">Supplier</label>
                    <select asp-for="SupplierId" asp-items="ViewBag.Suppliers" class="toolbar-input">
                        <option value="">Select</option>
                    </select>
                </div>

                <!-- Warehouse -->
                <div class="col-md-3">
                    <label class="form-label fw-medium">Warehouse</label>
                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses" class="toolbar-input">
                        <option value="">Select</option>
                    </select>
                </div>

                <!-- Date -->
                <div class="col-md-3">
                    <label class="form-label fw-medium">Date</label>
                    <input asp-for="PurchaseDate" type="date" class="toolbar-input" />
                </div>

                <!-- PRODUCT SECTION FULL WIDTH -->
                <div class="col-12 pt-3">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold">Product Items</h6>

                        <button type="button" id="btnAddRow" class="btn btn-primary-sm">
                            + Add Product
                        </button>
                    </div>

                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody id="itemsBody">

                            @for (int i = 0; i < items.Count; i++)
                            {
                                <tr>

                                    <td>
                                        <select name="PurchaseItem[@i].ProductId" class="toolbar-input product">
                                            @foreach (var p in (IEnumerable<SelectListItem>)ViewBag.Products)
                                            {
                                                <option value="@p.Value"
                                                        selected="@(p.Value == items[i].ProductId.ToString() ? "selected" : null)">
                                                    @p.Text
                                                </option>
                                            }
                                        </select>
                                    </td>

                                    <td>
                                        <input name="PurchaseItem[@i].Quantity"
                                               value="@items[i].Quantity"
                                               class="toolbar-input qty" />
                                    </td>

                                    <td>
                                        <input name="PurchaseItem[@i].UnitPrice"
                                               value="@items[i].UnitPrice"
                                               class="toolbar-input price" />
                                    </td>

                                    <td class="row-total">
                                        @(items[i].Quantity * items[i].UnitPrice)
                                    </td>

                                    <td>
                                        <button type="button" class="btn btn-danger btn-sm remove">X</button>
                                    </td>

                                </tr>
                            }

                        </tbody>
                    </table>
                </div>

                <!-- TOTAL SECTION (Customer style like form fields) -->
                <div class="col-12 row g-3 pt-3 border-top">

                    <div class="col-md-3">
                        <label class="form-label fw-medium">Discount</label>
                        <input asp-for="Discount" id="discount" class="toolbar-input" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-medium">Tax</label>
                        <input asp-for="Tax" id="tax" class="toolbar-input"  />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-medium">VAT</label>
                        <input asp-for="Vat" id="vat" class="toolbar-input"  />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-medium">Transport</label>
                        <input asp-for="TransportCost" id="transport" class="toolbar-input"  />
                    </div>

                    <div class="col-12 text-end pt-3">
                        <h4 class="fw-bold">Grand Total</h4>

                        <input asp-for="GrandTotal"
                               id="grandTotal"
                               readonly
                               type="number"
                               step="0.01"
                               class="toolbar-input" />
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="col-12 d-flex gap-3 pt-4 border-top">

                    <button type="submit" class="btn btn-primary-sm">
                        Save Purchase
                    </button>

                    <a asp-action="Index" class="btn btn-outline-sm">
                        Cancel
                    </a>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {

    <script>

        let i = @items.Count;

        let products = @Html.Raw(JsonSerializer.Serialize(
                    ((IEnumerable<SelectListItem>)ViewBag.Products)
                    .Select(x => new
                    {
                            value = x.Value,
                            text = x.Text
                    })
            ));

        function productOptions() {

            let html = '<option value="">Select Product</option>';

            products.forEach(function (p) {
                html += `<option value="${p.value}">${p.text}</option>`;
            });

            return html;
        }

        $("#btnAddRow").on("click", function () {

            $("#itemsBody").append(`
                <tr>

                    <td>
                        <select name="PurchaseItem[${i}].ProductId"
                                class="toolbar-input product">
                            ${productOptions()}
                        </select>
                    </td>

                    <td>
                        <input type="number"
                               step="0.01"
                               value="0"
                               name="PurchaseItem[${i}].Quantity"
                               class="toolbar-input qty" />
                    </td>

                    <td>
                        <input type="number"
                               step="0.01"
                               value="0"
                               name="PurchaseItem[${i}].UnitPrice"
                               class="toolbar-input price" />
                    </td>

                    <td class="row-total">0.00</td>

                    <td>
                        <button type="button"
                                class="btn btn-danger btn-sm remove">
                            X
                        </button>
                    </td>

                </tr>
            `);

            i++;

            calc();
        });

        $(document).on("click", ".remove", function () {

            $(this).closest("tr").remove();

            reIndex();

            calc();
        });

        $(document).on(
            "input",
            ".qty,.price,#discount,#tax,#vat,#transport",
            function () {
                calc();
            }
        );

        function reIndex() {

            $("#itemsBody tr").each(function (index) {

                $(this)
                    .find(".product")
                    .attr("name", `PurchaseItem[${index}].ProductId`);

                $(this)
                    .find(".qty")
                    .attr("name", `PurchaseItem[${index}].Quantity`);

                $(this)
                    .find(".price")
                    .attr("name", `PurchaseItem[${index}].UnitPrice`);
            });

            i = $("#itemsBody tr").length;
        }

        function calc() {

            let subtotal = 0;

            $("#itemsBody tr").each(function () {

                let qty =
                    parseFloat($(this).find(".qty").val()) || 0;

                let price =
                    parseFloat($(this).find(".price").val()) || 0;

                let rowTotal = qty * price;

                $(this)
                    .find(".row-total")
                    .html(rowTotal.toFixed(2));

                subtotal += rowTotal;
            });

            let discount =
                parseFloat($("#discount").val()) || 0;

            let tax =
                parseFloat($("#tax").val()) || 0;

            let vat =
                parseFloat($("#vat").val()) || 0;

            let transport =
                parseFloat($("#transport").val()) || 0;

            let grandTotal =
                subtotal +
                tax +
                vat +
                transport -
                discount;

            $("#grandTotal").val(grandTotal.toFixed(2));
        }

        $(document).ready(function () {

            calc();

        });

    </script>

}