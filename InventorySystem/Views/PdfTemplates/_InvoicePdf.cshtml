<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INVOICE - FIX SERVICE CENTER LTD.</title>
    <style>
            .inv-root {
                margin: 0;
                padding: 40px 16px;
                font-family: Arial, Helvetica, sans-serif;
                -webkit-font-smoothing: auto;
                background-color: #f0f0f0;
                color: #000000;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: flex-start;
            }

            .inv-page {
                max-width: 800px;
                width: 100%;
                background-color: #ffffff;
                border: 1px solid #d0d0d0;
                padding: 48px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            }

            .inv-top-line {
                height: 4px;
                background-color: #1a5276;
                margin: -48px -48px 36px -48px;
            }

            .inv-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 32px;
            }

            .inv-company {
            }

            .inv-company-name {
                font-size: 20px;
                font-weight: bold;
                color: #000000;
                margin: 0 0 4px 0;
            }

            .inv-company-tag {
                font-size: 11px;
                color: #1a5276;
                font-weight: normal;
                letter-spacing: 0.5px;
                margin: 0 0 10px 0;
            }

            .inv-company-info {
                font-size: 12px;
                color: #444444;
                line-height: 1.7;
                margin: 0;
            }

            .inv-invoice-label {
                font-size: 32px;
                font-weight: bold;
                color: #000000;
                text-align: right;
                margin: 0 0 12px 0;
            }

            .inv-meta-row {
                font-size: 12px;
                color: #444444;
                text-align: right;
                line-height: 1.8;
                margin: 0;
            }

            .inv-meta-val {
                color: #000000;
                font-weight: bold;
            }

            .inv-hr {
                border: none;
                border-top: 2px solid #000000;
                margin: 0 0 28px 0;
            }

            .inv-hr-light {
                border: none;
                border-top: 1px solid #dddddd;
                margin: 0 0 28px 0;
            }

            .inv-billto {
                display: flex;
                justify-content: space-between;
                margin-bottom: 28px;
            }

            .inv-billto-block {
            }

            .inv-label-sm {
                font-size: 11px;
                font-weight: bold;
                color: #000000;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin: 0 0 8px 0;
            }

            .inv-client-name {
                font-size: 14px;
                font-weight: bold;
                color: #000000;
                margin: 0 0 4px 0;
            }

            .inv-client-info {
                font-size: 12px;
                color: #444444;
                line-height: 1.7;
                margin: 0;
            }

            .inv-status {
                display: inline-block;
                padding: 4px 14px;
                border: 1px solid #1a5276;
                border-radius: 3px;
                font-size: 11px;
                font-weight: bold;
                color: #1a5276;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 8px;
            }

            .inv-table-wrap {
                margin-bottom: 24px;
            }

            .inv-table {
                width: 100%;
                border-collapse: collapse;
            }

            .inv-thead {
            }

            .inv-th {
                padding: 10px 14px;
                font-size: 11px;
                font-weight: bold;
                color: #ffffff;
                background-color: #1a5276;
                text-align: left;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border: 1px solid #154360;
            }

            .inv-th-right {
                text-align: right;
            }

            .inv-th-center {
                text-align: center;
            }

            .inv-td {
                padding: 12px 14px;
                font-size: 13px;
                color: #000000;
                border: 1px solid #dddddd;
                vertical-align: top;
            }

            .inv-td-id {
                font-weight: bold;
                text-align: center;
                width: 50px;
                background-color: #f7f7f7;
            }

            .inv-td-desc-name {
                font-weight: bold;
                font-size: 13px;
                color: #000000;
                margin: 0 0 2px 0;
            }

            .inv-td-desc-sub {
                font-size: 11px;
                color: #777777;
                margin: 0;
            }

            .inv-td-qty {
                text-align: center;
                color: #444444;
            }

            .inv-td-amt {
                text-align: right;
                font-weight: bold;
                color: #000000;
            }

            .inv-tbody-row:hover {
                background-color: #f9f9f9;
            }

            .inv-totals {
                display: flex;
                justify-content: flex-end;
                margin-bottom: 28px;
            }

            .inv-totals-box {
                width: 260px;
                border: 1px solid #dddddd;
            }

            .inv-totals-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 10px 16px;
                border-bottom: 1px solid #eeeeee;
            }

                .inv-totals-row:last-child {
                    border-bottom: none;
                }

            .inv-totals-label {
                font-size: 13px;
                color: #444444;
            }

            .inv-totals-label-bold {
                font-size: 13px;
                font-weight: bold;
                color: #000000;
            }

            .inv-totals-val {
                font-size: 13px;
                color: #000000;
            }

            .inv-totals-total {
                background-color: #1a5276;
                border-bottom: none;
            }

                .inv-totals-total .inv-totals-label-bold {
                    color: #ffffff;
                }

            .inv-totals-big {
                font-size: 18px;
                font-weight: bold;
                color: #ffffff;
            }

            .inv-notes {
                padding: 14px 16px;
                background-color: #f7f7f7;
                border: 1px solid #e0e0e0;
                margin-bottom: 32px;
            }

            .inv-notes-label {
                font-size: 11px;
                font-weight: bold;
                color: #000000;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin: 0 0 6px 0;
            }

            .inv-notes-text {
                font-size: 12px;
                color: #444444;
                line-height: 1.7;
                margin: 0;
            }

            .inv-footer {
                display: flex;
                justify-content: space-between;
                align-items: flex-end;
                padding-top: 28px;
                border-top: 1px solid #dddddd;
            }

            .inv-sig-area {
            }

            .inv-sig-line {
                width: 200px;
                height: 1px;
                border-bottom: 1px solid #000000;
                margin-bottom: 6px;
            }

            .inv-sig-label {
                font-size: 10px;
                color: #777777;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin: 0 0 2px 0;
            }

            .inv-sig-name {
                font-size: 13px;
                font-weight: bold;
                color: #000000;
                margin: 0;
            }

            .inv-qr-area {
                display: flex;
                flex-direction: column;
                align-items: flex-end;
            }

            .inv-qr-box {
                width: 72px;
                height: 72px;
                background-color: #ffffff;
                border: 1px solid #dddddd;
                padding: 4px;
            }

            .inv-qr-svg {
                width: 100%;
                height: 100%;
            }

            .inv-qr-text {
                font-size: 10px;
                color: #999999;
                margin: 4px 0 0 0;
            }

            .inv-bottom {
                display: flex;
                justify-content: center;
                gap: 24px;
                padding-top: 20px;
                border-top: 1px solid #eeeeee;
                margin-top: 24px;
            }

            .inv-bottom-item {
                font-size: 10px;
                color: #999999;
            }

            @@media (max-width: 640px) {
                .inv-page {
                    padding: 24px 20px;
                }

                .inv-top-line {
                    margin: -24px -20px 24px -20px;
                }

                .inv-header {
                    flex-direction: column;
                    gap: 16px;
                }

                .inv-invoice-label,
                .inv-meta-row {
                    text-align: left;
                }

                .inv-billto {
                    flex-direction: column;
                    gap: 16px;
                }

                .inv-td-desc-sub {
                    display: none;
                }

                .inv-th,
                .inv-td {
                    padding: 8px 8px;
                    font-size: 11px;
                }

                .inv-totals-box {
                    width: 100%;
                }

                .inv-footer {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 24px;
                }

                .inv-qr-area {
                    align-items: flex-start;
                }

                .inv-bottom {
                    flex-wrap: wrap;
                    gap: 8px 16px;
                }
            }
    </style>
</head>
