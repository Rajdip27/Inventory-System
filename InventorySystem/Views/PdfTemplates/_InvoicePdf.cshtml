@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Invoice</title>
    <style>
            /* ── RESET ── */
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                /* font-family: 'Helvetica Neue', Arial, Helvetica, sans-serif; */
                font-size: 12px;
                background: #f0f0f0;
                color: #000000;
                padding: 20px;
                margin: 0;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
            }

            /* ── A4 PAGE ── */
           /*  .invoice-wrapper {
                width: 210mm;
                margin: 0 auto;
                padding: 10mm 12mm 12mm 12mm;
                background: #ffffff;
                position: relative;
                min-height: 297mm;
                box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
            } */

            /* ── HEADER ── */
            .header {
                border-bottom: 3px solid #000000;
                padding-bottom: 10px;
                margin-bottom: 14px;
                overflow: hidden;
            }

            .header-left {
                float: left;
                width: 60%;
            }

            .header-right {
                float: right;
                width: 40%;
                text-align: right;
                padding-top: 8px;
            }

            .company-name {
                font-size: 22px;
                font-weight: 900;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: #000000;
            }

            .company-details {
                font-size: 11px;
              /*   color: #444444; */
                line-height: 1.7;
                margin-top: 4px;
            }

                .company-details a {
                    color: #000000;
                    text-decoration: none;
                    font-weight: 500;
                }

            .invoice-title {
                font-size: 26px;
                font-weight: 900;
                letter-spacing: 4px;
                text-transform: uppercase;
                color: #000000;
                position: relative;
            }

                .invoice-title::after {
                    content: '';
                    display: block;
                    width: 60px;
                    height: 3px;
                    background: #000000;
                    margin-left: auto;
                    margin-top: 4px;
                }

            .clearfix {
                clear: both;
            }

            /* ── INFO SECTION ── */
            .info-section {
                margin-bottom: 16px;
                overflow: hidden;
                padding: 8px 0;
            }

            .bill-to {
                float: left;
                width: 50%;
                padding-right: 20px;
            }

            .bill-to-label {
                font-size: 10px;
                font-weight: 700;
               /*  color: #888888; */
                text-transform: uppercase;
                letter-spacing: 1px;
                border-bottom: 2px solid #000000;
                padding-bottom: 3px;
                display: inline-block;
                margin-bottom: 6px;
            }

            .client-name {
                font-size: 15px;
                font-weight: 700;
                color: #000000;
                margin-bottom: 4px;
            }

            .client-details {
                font-size: 11px;
               /*  color: #444444; */
                line-height: 1.7;
            }

            .invoice-meta {
                float: right;
                width: 50%;
                padding-left: 20px;
            }

            .meta-row {
                font-size: 11px;
                padding: 3px 0;
                line-height: 1.6;
                text-align: right;
                display: flex;
                justify-content: flex-end;
                align-items: center;
            }

            .meta-label {
                font-weight: 600;
               /*  color: #888888; */
                min-width: 95px;
                text-align: right;
                text-transform: uppercase;
                font-size: 10px;
                letter-spacing: 0.5px;
            }

            .meta-value {
                color: #000000;
                font-weight: 600;
                min-width: 150px;
                text-align: left;
                padding-left: 12px;
            }

            .sold-by {
                font-size: 11px;
               /*  color: #444444; */
                margin-top: 6px;
                line-height: 1.7;
                text-align: right;
                padding-top: 4px;
                border-top: 1px dashed #dddddd;
            }

                .sold-by strong {
                    color: #000000;
                    font-weight: 700;
                }

            .paid-badge {
                display: inline-block;
                font-size: 12px;
                font-weight: 900;
                color: #000000;
                border: 3px solid #000000;
                padding: 3px 22px;
                letter-spacing: 2px;
                text-transform: uppercase;
                margin-top: 6px;
                background: #ffffff;
            }

            /* ── REMARKS ── */
            .remarks {
                font-size: 11px;
               /*  color: #555555; */
                margin-bottom: 12px;
                padding: 6px 0;
            }

            .remarks-label {
                font-weight: 700;
                color: #000000;
            }

            /* ── ITEMS TABLE ── */
            .items-table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 8px;
            }

                .items-table thead th {
                    background: #000000;
                    color: #ffffff;
                    font-size: 10px;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    padding: 10px 12px;
                    text-align: center;
                }

                    .items-table thead th.desc-header {
                        text-align: left;
                        width: 52%;
                    }

                .items-table tbody td {
                    font-size: 12px;
                    color: #000000;
                    padding: 11px 12px;
                    border-bottom: 1px solid #e8e8e8;
                    vertical-align: middle;
                }

                .items-table tbody tr:last-child td {
                    border-bottom: 3px solid #000000;
                }

            .desc-cell {
                font-weight: 600;
                text-align: left;
            }

            .qty-cell,
            .unit-cell,
            .total-cell {
                text-align: center;
                font-weight: 500;
            }

            /* ── TOTALS ── */
            .totals-section {
                margin-top: 6px;
                overflow: hidden;
                padding: 6px 0;
            }

            .totals-table {
                float: right;
                border-collapse: collapse;
                width: 300px;
            }

                .totals-table td {
                    font-size: 11px;
                    padding: 5px 14px;
                    border-bottom: 1px solid #e8e8e8;
                    color: #000000;
                }

            .totals-label {
                font-weight: 600;
               /*  color: #888888; */
                text-align: left;
                text-transform: uppercase;
                font-size: 10px;
                letter-spacing: 0.5px;
            }

            .totals-value {
                font-weight: 600;
                color: #000000;
                text-align: right;
                white-space: nowrap;
            }

            .grand-total td {
                padding: 10px 14px 6px 14px !important;
                border-bottom: none !important;
                border-top: 3px solid #000000;
            }

            .grand-label {
                font-size: 15px;
                font-weight: 800;
                text-transform: uppercase;
                color: #000000;
                text-align: left;
                letter-spacing: 1px;
            }

            .grand-value {
                font-size: 22px;
                font-weight: 900;
                color: #000000;
                text-align: right;
                white-space: nowrap;
            }

            /* ── TERMS ── */
            .terms-section {
                margin-top: 18px;
                padding: 10px 0;
                border-top: 2px solid #000000;
            }

            .terms-title {
                font-size: 12px;
                font-weight: 700;
                color: #000000;
                margin-bottom: 6px;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .terms-list {
                font-size: 10px;
               /*  color: #444444; */
                line-height: 1.6;
                padding-left: 0;
                list-style: none;
            }

                .terms-list li {
                    padding: 2px 0;
                }

                    .terms-list li::before {
                        content: counter(item) ". ";
                        font-weight: 700;
                        color: #000000;
                    }

                .terms-list li {
                    counter-increment: item;
                }

            .terms-list {
                counter-reset: item;
            }

            /* ── FOOTER ── */
            .footer {
                margin-top: 28px;
                padding: 14px 0 8px 0;
                border-top: 2px solid #000000;
                overflow: hidden;
            }

            .signature-left {
                float: left;
                width: 30%;
                text-align: center;
            }

            .signature-center {
                float: left;
                width: 40%;
                text-align: center;
            }

            .signature-right {
                float: right;
                width: 30%;
                text-align: center;
            }

            .signature-line {
                border: none;
                border-top: 2px solid #000000;
                width: 160px;
                margin: 0 auto 5px auto;
            }

            .signature-label {
                font-size: 10px;
                font-weight: 600;
               /*  color: #888888; */
                letter-spacing: 0.5px;
                text-transform: uppercase;
            }

            .qr-code {
                width: 72px;
                height: 72px;
                display: block;
                margin: 0 auto 5px auto;
            }

            /* ── PRINT STYLES ── */
            @@media print {
                body {
                    background: #ffffff;
                    padding: 0;
                    margin: 0;
                    display: block;
                }

                .invoice-wrapper {
                    width: 100%;
                    padding: 10mm 12mm;
                    min-height: auto;
                    box-shadow: none;
                }

                .items-table tbody td {
                    border-bottom: 1px solid #cccccc;
                }
            }
    </style>
</head>
