
@using InventorySystem.Cmmon
@model List<CustomerPayment>

@{
    ViewData["Title"] = "Customer Payments";
    int sl = 1;
}

<div class="page-content">

    <div class="table-card">

        <!-- HEADER -->
        <div class="table-card-header">

            <div>
                <h5 class="table-card-title">Customer Payments</h5>
                <small class="table-card-subtitle">
                    Manage all customer payments • @(Model?.Count ?? 0) items
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <!-- FILTER -->
                <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">

                    <select name="customerId"
                            asp-items="ViewBag.Customers"
                            class="form-select"
                            style="width:220px;">
                        <option value="">All Customers</option>
                    </select>

                    <select name="invoiceId"
                            asp-items="ViewBag.Invoices"
                            class="form-select"
                            style="width:220px;">
                        <option value="">All Invoices</option>
                    </select>

                    <button type="submit" class="btn btn-primary-sm">
                        <i class="ri-search-line"></i>
                    </button>

                    <a asp-action="Index" class="btn btn-secondary-sm">
                        Reset
                    </a>

                </form>

                <!-- CREATE -->
                <a asp-action="CreateAndEdit"
                   class="btn btn-primary-sm d-flex align-items-center gap-2">
                    <i class="ri-add-line"></i>
                    New Payment
                </a>

            </div>

        </div>

        <!-- TABLE -->
        <div class="table-responsive">

            <table class="data-table">

                <thead>
                    <tr>
                        <th style="width:60px;">SL</th>
                        <th>Customer</th>
                        <th>Invoice</th>
                        <th>Date</th>
                        <th>Method</th>
                        <th class="text-end">Amount</th>
                        <th style="width:120px;" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="text-center">@sl</td>

                                <td class="fw-semibold">
                                    @(item.Customer?.Name ?? "-")
                                </td>

                                <td>
                                    @(item.SalesInvoice?.InvoiceNo ?? "-")
                                </td>

                                <td>
                                    @item.PaymentDate.ToString("dd-MM-yyyy")
                                </td>

                                <td>
                                    <span class="badge bg-light text-dark">
                                        @item.PaymentMethod
                                    </span>
                                </td>

                                <td class="text-end fw-semibold">
                                    @item.Amount.ToString("N2")
                                </td>

                                <td class="text-center">

                                    <div class="action-btns">

                                        <a asp-action="CreateAndEdit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--edit">
                                            <i class="ri-edit-line"></i>
                                        </a>

                                    </div>

                                </td>

                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="ri-money-dollar-circle-line" style="font-size:42px;"></i>
                                <p>No customer payments found</p>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

