@using InventorySystem.Cmmon
@using InventorySystem.HealperUnit
@inject ISignInHelper SignInHelper
@model PaginationModel<Invoice>

@{
    string currentSearch = Context.Request.Query["search"].ToString() ?? "";
    int sl = ((Model?.PageNumber - 1) * Model?.PageSize ?? 0) + 1;
}

<div class="page-content">

    <!-- TABLE CARD -->
    <div class="table-card">

        <!-- HEADER -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">Invoice List</h5>
                <small class="table-card-subtitle">
                    Manage all invoices • @Model?.TotalItems items
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <!-- SEARCH -->
                <form method="get" class="d-flex gap-2">
                    <div class="search-field" style="width: 280px;">
                        <i class="ri-search-line"></i>
                        <input type="text"
                               name="search"
                               class="toolbar-input"
                               placeholder="Search invoice no..."
                               value="@currentSearch" />
                        <input type="hidden" name="page" value="1" />
                    </div>

                    <button class="btn btn-primary-sm" type="submit">
                        <i class="ri-search-line"></i>
                    </button>
                </form>

                <!-- CREATE BUTTON -->
                <a asp-controller="Invoice"
                   asp-action="CreateAndEdit"
                   class="btn btn-primary-sm d-flex align-items-center gap-2">
                    <i class="ri-add-line"></i> New Invoice
                </a>

            </div>
        </div>

        <!-- TABLE -->
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">SL</th>
                        <th>Invoice No</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Grand Total</th>
                        <th>Paid</th>
                        <th>Due</th>
                        <th>Status</th>
                        <th style="width: 130px;" class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>

                                <td class="text-center fw-medium">@sl</td>

                                <td class="fw-semibold">
                                    @item.InvoiceNo
                                </td>

                                <td>
                                    @item.Customer?.CustomerName
                                </td>

                                <td>
                                    @item.InvoiceDate.ToString("dd-MMM-yyyy")
                                </td>

                                <td>
                                    @item.GrandTotal
                                </td>

                                <td>
                                    @item.PaidAmount
                                </td>

                                <td>
                                    @item.DueAmount
                                </td>

                                <td>
                                    @if (item.PaymentStatus == "paid")
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else if (item.PaymentStatus == "partial")
                                    {
                                        <span class="badge bg-warning">Partial</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Due</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="action-btns">

                                        <!-- EDIT -->
                                        <a asp-controller="Invoice"
                                           asp-action="CreateAndEdit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--edit"
                                           title="Edit">
                                            <i class="ri-edit-line"></i>
                                        </a>

                                        <!-- DETAILS -->
                                        <a asp-controller="Invoice"
                                           asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--view"
                                           title="Details">
                                            <i class="ri-eye-line"></i>
                                        </a>

                                        <!-- DELETE -->
                                        <a href="javascript:void(0);"
                                           class="action-btn action-btn--delete"
                                           onclick="confirmDelete('/Invoice/Delete/@item.Id')"
                                           title="Delete">
                                            <i class="ri-delete-bin-6-line"></i>
                                        </a>

                                    </div>
                                </td>

                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="empty-state">
                                <i class="ri-inbox-line" style="font-size: 42px;"></i>
                                <p>No invoices found</p>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination-bar">
            <partial name="_Pagination" model="Model" />
        </div>

    </div>
</div>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
