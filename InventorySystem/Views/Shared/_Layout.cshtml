<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory Admin</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- Custom CSS -->
    <link href="~/css/dashboard.css" rel="stylesheet" />
    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- jQuery (required) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <!-- Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">
</head>
<body>

    <!-- ========== SIDEBAR ========== -->
    <aside class="sidebar" id="sidebar">

        <!-- Logo / Brand -->
        <div class="sidebar-brand">
            @* <span class="brand-icon"><i class="bi bi-boxes"></i></span> *@
            <span class="brand-text">InvenTrack</span>
        </div>

        <!-- Navigation Menu -->
        <nav class="sidebar-nav">

            <div class="nav-section-label">Main</div>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               href="/Dashboard">
                <i class="bi bi-grid-1x2-fill nav-icon"></i>
                <span>Dashboard</span>
            </a>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")"
               href="/Inventory">
                <i class="bi bi-box-seam-fill nav-icon"></i>
                <span>Inventory</span>
            </a>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")"
               href="/Customer/Index">
                <i class="bi bi-people-fill nav-icon"></i>
                <span>Customers</span>
            </a>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Orders" ? "active" : "")"
               href="/Orders">
                <i class="bi bi-cart4 nav-icon"></i>
                <span>Orders</span>
                <span class="nav-badge">12</span>
            </a>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Suppliers" ? "active" : "")"
               href="/Suppliers">
                <i class="bi bi-truck nav-icon"></i>
                <span>Suppliers</span>
            </a>

            <div class="nav-section-label">Reports</div>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
               href="/Reports">
                <i class="bi bi-bar-chart-line-fill nav-icon"></i>
                <span>Reports</span>
            </a>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")"
               href="/Analytics">
                <i class="bi bi-graph-up-arrow nav-icon"></i>
                <span>Analytics</span>
            </a>

            <div class="nav-section-label">System</div>

            <a class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
               href="/Settings">
                <i class="bi bi-gear-fill nav-icon"></i>
                <span>Settings</span>
            </a>

        </nav>

        <!-- Sidebar Footer (user info) -->
        <div class="sidebar-footer">
            <div class="user-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="user-info">
                <div class="user-name">Admin User</div>
                <div class="user-role">Super Admin</div>
            </div>
            <a href="/Account/Logout" class="logout-btn" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
    </aside>

    <!-- ========== MAIN WRAPPER ========== -->
    <div class="main-wrapper" id="mainWrapper">

        <!-- ========== TOP BAR ========== -->
        <header class="topbar">

            <!-- Left: Toggle sidebar (mobile) + Page title -->
            <div class="topbar-left">
                <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
               @*  <div class="page-title-area">
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    <nav class="breadcrumb-nav" aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a href="/Dashboard"><i class="bi bi-house-fill"></i></a>
                            </li>
                            @if (ViewData["Title"]?.ToString() != "Dashboard")
                            {
                                <li class="breadcrumb-item active">@ViewData["Title"]</li>
                            }
                        </ol>
                    </nav>
                </div> *@
            </div>

            <!-- Right: Search, Notifications, Dark Mode Toggle -->
            <div class="topbar-right">

                <!-- Search box -->
                <div class="topbar-search">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" placeholder="Search products, orders..." class="search-input" />
                </div>

                <!-- Notification Bell -->
                <button class="topbar-icon-btn" title="Notifications">
                    <i class="bi bi-bell-fill"></i>
                    <span class="notification-dot"></span>
                </button>

                <!-- Dark / Light Mode Toggle -->
                <button class="theme-toggle" id="themeToggle" onclick="toggleTheme()"
                        title="Toggle dark/light mode" aria-label="Toggle dark/light mode">
                    <span class="theme-icon light-icon"><i class="bi bi-sun-fill"></i></span>
                    <span class="theme-icon dark-icon"><i class="bi bi-moon-fill"></i></span>
                    <span class="theme-slider"></span>
                </button>

                <!-- Profile -->
                <button class="topbar-icon-btn profile-btn" title="Profile">
                    <i class="bi bi-person-circle"></i>
                </button>
            </div>
        </header>

        <!-- ========== PAGE CONTENT ========== -->
        <main class="page-content">
            @RenderBody()
        </main>

        <!-- ========== FOOTER ========== -->
        <footer class="page-footer">
            <span>&copy; @DateTime.Now.Year InvenTrack &mdash; Inventory Management System</span>
            <span>v1.0.0</span>
        </footer>

    </div><!-- end .main-wrapper -->
    <!-- Sidebar Overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <div id="loader" style="display:none;">
        <div class="loader"></div>
    </div>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom Theme + Dashboard JS -->
    <script src="~/js/dashboard.js"></script>

    <script src="~/js/site.js"></script>

    <script>
        toastr.options = {
        "closeButton": true,
        "progressBar": true,
        "positionClass": "toast-top-right",
        "timeOut": "3000"
        };

        @if (TempData["success"] != null)
        {
            <text>toastr.success('@TempData["success"]');</text>
        }

        @if (TempData["error"] != null)
        {
            <text>toastr.error('@TempData["error"]');</text>
        }

        @if (TempData["warning"] != null)
        {
            <text>toastr.warning('@TempData["warning"]');</text>
        }

        @if (TempData["info"] != null)
        {
            <text>toastr.info('@TempData["info"]');</text>
        }
    </script>
 

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
