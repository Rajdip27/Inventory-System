@using InventorySystem.Cmmon
@using InventorySystem.HealperUnit
@inject ISignInHelper SignInHelper
@model PaginationModel<Customer>

@{
    string currentSearch = Context.Request.Query["search"].ToString() ?? "";
    int sl = (Model?.PageNumber - 1) * Model.PageSize + 1 ?? 1;
}

<div class="page-content">

    <!-- TABLE CARD -->
    <div class="table-card">

        <!-- Header with Top Color Accent -->
        <div class="table-card-header">
            <div>
                <h5 class="table-card-title">Customer List</h5>
                <small class="table-card-subtitle">
                    Manage all customers • @Model?.TotalItems items
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">
                <!-- Search -->
                <form method="get" class="d-flex gap-2">
                    <div class="search-field" style="width: 280px;">
                        <i class="ri-search-line"></i>
                        <input type="text"
                               name="search"
                               class="toolbar-input"
                               placeholder="Search by name, phone or email..."
                               value="@currentSearch" />
                        <input type="hidden" name="page" value="1" />
                    </div>
                    <button class="btn btn-primary-sm" type="submit">
                        <i class="ri-search-line"></i>
                    </button>
                </form>

                <!-- Create Button -->
                <a asp-controller="Customer"
                   asp-action="CreateAndEdit"
                   class="btn btn-primary-sm d-flex align-items-center gap-2">
                    <i class="ri-add-line"></i> New Customer
                </a>
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 60px;">SL</th>
                        <th>Customer Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th style="width: 110px;" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-center fw-medium">@sl</td>
                                <td class="fw-semibold">@item.Name</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td class="text-truncate" style="max-width: 260px;" title="@item.Address">
                                    @item.Address
                                </td>
                                <td class="text-center">
                                    <div class="action-btns">
                                        <!-- Edit -->
                                        <a asp-controller="Customer"
                                           asp-action="CreateAndEdit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-btn--edit"
                                           title="Edit">
                                            <i class="ri-edit-line"></i>
                                        </a>
                                      <a href="javascript:void(0);"
                                        class="btn btn-danger btn-sm"
                                           onclick="confirmDelete('/Customer/Delete/@item.Id')">
                                            <i class="ri-delete-bin-6-line"></i>
                                    </a>
                                    </div>
                                </td>
                            </tr>
                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="ri-inbox-line" style="font-size: 42px;"></i>
                                <p>No customers found</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-bar">
            <partial name="_Pagination" model="Model" />
        </div>

    </div>

</div>