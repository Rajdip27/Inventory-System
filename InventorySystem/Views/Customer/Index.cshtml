@using InventorySystem.Cmmon
@using InventorySystem.HealperUnit
@inject ISignInHelper SignInHelper
@model PaginationModel<Customer>

@{
    string currentSearch = Context.Request.Query["search"].ToString() ?? "";
    int sl = (Model != null)
        ? ((Model.PageNumber - 1) * Model.PageSize) + 1
        : 1;

    var role = SignInHelper.Roles;
}

<style>
    /* ===== SMART TABLE ===== */
    .smart-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
    }

    .smart-table {
        margin-bottom: 0;
        font-size: 14px;
        border-collapse: separate;
        border-spacing: 0;
    }

        .smart-table thead th {
            background: #f9fafb;
            font-weight: 600;
            padding: 12px 14px;
            border-bottom: 2px solid #e5e7eb;
        }

        .smart-table tbody td {
            padding: 12px 14px;
            border-bottom: 1px solid #e5e7eb;
            vertical-align: middle;
        }

        .smart-table tbody tr:hover {
            background: #f3f4f6;
        }

    /* ACTION BUTTONS */
    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        border: 1px solid transparent;
    }

    .action-edit {
        background: #eff6ff;
        color: #2563eb;
        border-color: #dbeafe;
    }

        .action-edit:hover {
            background: #2563eb;
            color: #fff;
        }

    .action-delete {
        background: #fef2f2;
        color: #dc2626;
        border-color: #fee2e2;
    }

        .action-delete:hover {
            background: #dc2626;
            color: #fff;
        }

    /* HEADER */
    .page-header {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 15px;
    }

        .page-header h4 {
            margin: 0;
            font-weight: 600;
        }

        .page-header small {
            color: #6b7280;
        }
</style>

<div class="content-area">

    <!-- HEADER -->
    <div class="page-header">
        <div>
            <h4>Customer List</h4>
            <small>Manage all customers</small>
        </div>

        <div class="d-flex gap-2">

            <!-- SEARCH -->
            <form method="get" class="d-flex gap-2">
                <input type="text"
                       name="search"
                       class="form-control form-control-sm"
                       placeholder="Search customer..."
                       value="@currentSearch" />

                <input type="hidden" name="page" value="1" />

                <button class="btn btn-outline-secondary btn-sm">
                    <i class="ri-search-line"></i>
                </button>
            </form>

            <!-- CREATE -->
            <a asp-controller="Customer"
               asp-action="Create"
               class="btn btn-primary btn-sm">
                <i class="ri-add-line"></i> Create
            </a>

        </div>
    </div>

    <!-- TABLE -->
    <div class="smart-card">
        <div class="table-responsive">

            <table class="table smart-table">

                <thead>
                    <tr>
                        <th style="width:70px;">SL</th>
                        <th>Customer Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th style="width:130px;" class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model?.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>

                                <td>@sl</td>

                                <td class="fw-semibold text-dark">
                                    @item.CustomerName
                                </td>

                                <td>@item.Phone</td>

                                <td>@item.Email</td>

                                <td>@item.Address</td>

                                <td class="text-center">

                                    <div class="d-inline-flex gap-2">

                                        <!-- EDIT -->
                                        <a asp-controller="Customer"
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="action-btn action-edit"
                                           title="Edit">
                                            <i class="ri-edit-line"></i>
                                        </a>

                                        <!-- DELETE -->
                                        <form asp-controller="Customer"
                                              asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              onsubmit="return confirm('Delete this customer?');">

                                            <button type="submit"
                                                    class="action-btn action-delete"
                                                    title="Delete">
                                                <i class="ri-delete-bin-6-line"></i>
                                            </button>

                                        </form>

                                    </div>

                                </td>

                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                No customers found
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-end mt-3">
        <partial name="_Pagination" model="Model" />
    </div>

</div>