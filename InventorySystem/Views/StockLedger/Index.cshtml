@model List<StockLedger>

@{
    ViewData["Title"] = "Stock Ledger";

    int sl = 1;

    bool isSearch =
        ViewBag.ProductId != null ||
        ViewBag.WarehouseId != null ||
        ViewBag.StartDate != null ||
        ViewBag.EndDate != null;

    decimal totalIn = Model?.Sum(x => x.StockIn) ?? 0;
    decimal totalOut = Model?.Sum(x => x.StockOut) ?? 0;
    decimal closingBalance = Model?.LastOrDefault()?.BalanceQty ?? 0;
}

<div class="page-content">

    <div class="table-card">

        <!-- Header -->
        <div class="table-card-header">

            <div>
                <h5 class="table-card-title">
                    Stock Ledger
                </h5>

                <small class="table-card-subtitle">
                    Track product stock movement
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <form method="get"
                      asp-action="Index"
                      class="d-flex gap-2 align-items-center">

                    <!-- Product -->
                    <div class="search-field" style="width:250px;">
                        <i class="ri-box-3-line"></i>

                        <select name="productId"
                                asp-items="ViewBag.Products"
                                class="toolbar-input">

                            <option value="">
                                Select Product
                            </option>

                        </select>

                    </div>

                    <!-- Warehouse -->
                    <div class="search-field" style="width:220px;">
                        <i class="ri-home-warehouse-line"></i>

                        <select name="warehouseId"
                                asp-items="ViewBag.Warehouses"
                                class="toolbar-input">

                            <option value="">
                                All Warehouses
                            </option>

                        </select>

                    </div>

                    <!-- Start Date -->
                    <div class="search-field" style="width:165px;">
                        <i class="ri-calendar-line"></i>

                        <input type="date"
                               name="startDate"
                               class="toolbar-input"
                               value="@ViewBag.StartDate" />

                    </div>

                    <!-- End Date -->
                    <div class="search-field" style="width:165px;">
                        <i class="ri-calendar-line"></i>

                        <input type="date"
                               name="endDate"
                               class="toolbar-input"
                               value="@ViewBag.EndDate" />

                    </div>

                    <!-- Search -->
                    <button type="submit"
                            class="btn btn-primary-sm">

                        <i class="ri-search-line"></i>

                    </button>

                    <!-- Reset -->
                    <a asp-action="Index"
                       class="btn btn-outline-secondary">

                        <i class="ri-refresh-line"></i>

                    </a>

                </form>

            </div>

        </div>

        <!-- Table -->

        <div class="table-responsive">

            <table class="data-table">

                <thead>

                    <tr>

                        <th style="width:60px;">SL</th>

                        <th>Date</th>

                        <th>Product</th>

                        <th>Warehouse</th>

                        <th>Reference</th>

                        <th class="text-end">
                            Unit Cost
                        </th>

                        <th class="text-end">
                            Stock In
                        </th>

                        <th class="text-end">
                            Stock Out
                        </th>

                        <th class="text-end">
                            Balance Qty
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @if (!isSearch)
                    {
                        <tr>

                            <td colspan="9"
                                class="empty-state">

                                <i class="ri-search-line"
                                   style="font-size:42px;"></i>

                                <p>
                                    Please select Product and click Search.
                                </p>

                            </td>

                        </tr>
                    }
                    else if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="text-center fw-medium">
                                    @sl
                                </td>

                                <td>
                                    @item.TransactionDate.ToString("dd-MMM-yyyy")
                                </td>

                                <td class="fw-semibold">
                                    @item.Product?.ProductName
                                </td>

                                <td>
                                    @item.Warehouse?.Name
                                </td>

                                <td>
                                    @item.ReferenceType
                                </td>

                                <td class="text-end">
                                    @item.UnitCost.ToString("N2")
                                </td>

                                <td class="text-end text-success fw-semibold">
                                    @item.StockIn.ToString("N2")
                                </td>

                                <td class="text-end text-danger fw-semibold">
                                    @item.StockOut.ToString("N2")
                                </td>

                                <td class="text-end fw-bold">
                                    @item.BalanceQty.ToString("N2")
                                </td>

                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="9"
                                class="empty-state">

                                <i class="ri-inbox-line"
                                   style="font-size:42px;"></i>

                                <p>
                                    No stock ledger found.
                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

                @if (isSearch && Model.Any())
                {
                    <tfoot>

                        <tr class="fw-bold">

                            <td colspan="6"
                                class="text-end">

                                Summary

                            </td>

                            <td class="text-end text-success">

                                @totalIn.ToString("N2")

                            </td>

                            <td class="text-end text-danger">

                                @totalOut.ToString("N2")

                            </td>

                            <td class="text-end text-primary">

                                @closingBalance.ToString("N2")

                            </td>

                        </tr>

                    </tfoot>
                }

            </table>

        </div>

    </div>

</div>