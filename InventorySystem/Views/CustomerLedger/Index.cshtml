@model List<CustomerLedger>

@{
    ViewData["Title"] = "Customer Ledger";

    int sl = 1;

    bool isSearch =
        ViewBag.CustomerId != null ||
        ViewBag.StartDate != null ||
        ViewBag.EndDate != null;

    decimal totalDebit = Model?.Sum(x => x.Debit) ?? 0;
    decimal totalCredit = Model?.Sum(x => x.Credit) ?? 0;
}

<div class="page-content">

    <div class="table-card">

        <!-- Header -->
        <div class="table-card-header">

            <div>
                <h5 class="table-card-title">Customer Ledger</h5>
                <small class="table-card-subtitle">
                    Manage all customer transactions
                </small>
            </div>

            <div class="d-flex gap-3 align-items-center">

                <form method="get" asp-action="Index" class="d-flex gap-2 align-items-center">

                    <!-- Customer -->
                    <div class="search-field" style="width:220px;">
                        <i class="ri-user-search-line"></i>

                        <select name="customerId" class="toolbar-input">
                            <option value="">Select Customer</option>

                            @foreach (var item in ViewBag.Customers)
                            {
                                if (ViewBag.CustomerId?.ToString() == item.Value)
                                {
                                    <option value="@item.Value" selected>
                                        @item.Text
                                    </option>
                                }
                                else
                                {
                                    <option value="@item.Value">
                                        @item.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Start Date -->
                    <div class="search-field" style="width:160px;">
                        <i class="ri-calendar-line"></i>

                        <input type="date"
                               name="startDate"
                               class="toolbar-input"
                               value="@ViewBag.StartDate" />
                    </div>

                    <!-- End Date -->
                    <div class="search-field" style="width:160px;">
                        <i class="ri-calendar-line"></i>

                        <input type="date"
                               name="endDate"
                               class="toolbar-input"
                               value="@ViewBag.EndDate" />
                    </div>

                    <button type="submit" class="btn btn-primary-sm">
                        <i class="ri-search-line"></i>
                    </button>

                    <a asp-action="Index" class="btn btn-primary-sm">
                        <i class="ri-refresh-line"></i>
                        Reset
                    </a>

                </form>

            </div>

        </div>

        <!-- Table -->
        <div class="table-responsive">

            <table class="data-table">

                <thead>
                    <tr>
                        <th style="width:60px;">SL</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Reference</th>
                        <th>Description</th>
                        <th class="text-end">Opening</th>
                        <th class="text-end">Debit</th>
                        <th class="text-end">Credit</th>
                        <th class="text-end">Closing</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!isSearch)
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <i class="ri-search-line" style="font-size:45px;"></i>
                                <br />
                                Please select Customer and Date Range then click Search.
                            </td>
                        </tr>
                    }
                    else if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td class="text-center">@sl</td>

                                <td>
                                    @item.TransactionDate.ToString("dd-MMM-yyyy")
                                </td>

                                <td>
                                    @item.Customer?.Name
                                </td>

                                <td>
                                    @item.ReferenceType
                                </td>

                                <td>
                                    @item.Description
                                </td>

                                <td class="text-end">
                                    @item.OpeningBalance.ToString("N2")
                                </td>

                                <td class="text-end text-danger fw-semibold">
                                    @item.Debit.ToString("N2")
                                </td>

                                <td class="text-end text-success fw-semibold">
                                    @item.Credit.ToString("N2")
                                </td>

                                <td class="text-end fw-bold">
                                    @item.ClosingBalance.ToString("N2")
                                </td>

                            </tr>

                            sl++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5">
                                <i class="ri-inbox-line" style="font-size:45px;"></i>
                                <br />
                                No ledger records found.
                            </td>
                        </tr>
                    }

                </tbody>

                @if (isSearch && Model != null && Model.Any())
                {
                    <tfoot>
                        <tr class="fw-bold">

                            <td colspan="6" class="text-end">
                                Total
                            </td>

                            <td class="text-end text-danger">
                                @totalDebit.ToString("N2")
                            </td>

                            <td class="text-end text-success">
                                @totalCredit.ToString("N2")
                            </td>

                            <td></td>

                        </tr>
                    </tfoot>
                }

            </table>

        </div>

    </div>

</div>